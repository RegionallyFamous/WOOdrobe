{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "woodrobe/showcase",
  "version": "1.0.0",
  "title": "WOOdrobe Showcase",
  "category": "design",
  "icon": "screenoptions",
  "description": "Preview a WOOdrobe style family in one live gallery.",
  "keywords": [
    "woocommerce",
    "styles",
    "product details",
    "product collection"
  ],
  "textdomain": "woodrobe",
  "attributes": {
    "blockName": {
      "type": "string",
      "default": "woocommerce/product-details"
    },
    "showHeader": {
      "type": "boolean",
      "default": true
    },
    "title": {
      "type": "string",
      "default": "WOOdrobe Style Showcase"
    },
    "description": {
      "type": "string",
      "default": "A live sampler of the WooCommerce block-style outfits included with WOOdrobe."
    }
  },
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "html": false,
    "spacing": {
      "margin": true
    }
  }
}
